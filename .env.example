# ==========================================
# OPENROUTER AI CONFIGURATION
# ==========================================
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY="your_openrouter_api_key_here"
# Recommended models with great tool-calling support:
# - meta-llama/llama-3.3-70b-instruct
# - openai/gpt-4o-mini
# - qwen/qwen-2.5-72b-instruct
OPENROUTER_MODEL="deepseek/deepseek-v4-flash"

# ==========================================
# TENNIS COURT CONFIGURATION
# ==========================================
COURT_1_NAME="Tennis Court 1"
COURT_2_NAME="Tennis Court 2"
CLUB_OPENING_HOUR="07:00"
CLUB_CLOSING_HOUR="22:00"
HOURLY_RATE_USD="40"

# ==========================================
# DATABASE & SCHEDULING CONFIGURATION
# ==========================================
# Local SQLite database by default (or Supabase/PostgreSQL URL: postgresql://user:pass@host:port/db)
DATABASE_URL="sqlite:///./tennis_courts.db"

# Optional: Google Calendar Integration
# If left empty, the chatbot will use the local SQL Database as the single source of truth!
GOOGLE_SERVICE_ACCOUNT_FILE=""
GOOGLE_CALENDAR_ID_COURT_1=""
GOOGLE_CALENDAR_ID_COURT_2=""

# ==========================================
# WHATSAPP WEBHOOK & API CONFIGURATION
# ==========================================
# Meta Cloud API Settings
WHATSAPP_TOKEN="your_meta_cloud_api_token"
WHATSAPP_PHONE_NUMBER_ID="your_whatsapp_phone_id"
WHATSAPP_VERIFY_TOKEN="my_secret_verify_token_123"

# Optional: Evolution API / Baileys Open-Source Wrapper Settings
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE_NAME="tennis_bot"
